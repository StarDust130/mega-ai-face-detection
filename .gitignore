# Production-ready .gitignore for Next.js (frontend) + FastAPI (backend) + Docker
# - Covers Node/Next.js, Python/FastAPI, Docker, editors, OS artifacts and local caches
# - Keep lockfiles and examples (do NOT ignore `package-lock.json`, `yarn.lock`, `requirements.txt`, etc.)

#########################
# Node / Next.js
#########################
# Node modules
node_modules/

# Next.js build output
.next/
.next/cache/
out/
dist/
build/

# Static exported files
public/static/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-debug.log

# Caches
.cache/
parcel-cache/

#########################
# Environment files (keep .env.example)
#########################
# Local and secret env files
.env
.env.*.local
.env.local
!.env.example

#########################
# Python / FastAPI
#########################
# Bytecode
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
env/
.venv/
ENV/
env.bak/
__pypackages__/

# Packaging / distribution
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/
*.egg
*.whl
pyvenv.cfg

# Testing / coverage
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
.pytest_cache/
.mypy_cache/
.pyright/
.pyre/

# Uvicorn / Gunicorn logs
gunicorn.log
uvicorn.log

#########################
# Docker
#########################
# Local compose overrides and docker-specific envs
docker-compose.override.yml
docker-compose.local.yml
docker-compose.*.local.yml
.env.docker

# Docker helper folders / artifacts (adjust if you intentionally commit these)
.docker/
docker-volumes/
docker-data/

#########################
# Editors / IDEs
#########################
.vscode/
.idea/
*.sublime-workspace
*.sublime-project
*.code-workspace

#########################
# OS / Misc
#########################
.DS_Store
Thumbs.db
desktop.ini

# Secrets, keys and certs
secrets/
credentials/
*.pem
*.key
*.p12

# Generic logs / temp
*.log
logs/
tmp/
temp/
*.tmp
*.swp
*~
*.bak

# End of file

